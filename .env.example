# =============================================================================
# Lawer — AI-ассистент юридического отдела
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
#
# ВАЖНО: пароли должны содержать только безопасные символы (a-z A-Z 0-9 - _ . ~)
# Спецсимволы ($, #, !, @) вызывают проблемы с docker-compose и Prisma.
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=lawer
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lawer

# --- Redis --------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_strong_password_here
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT ----------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# --- MinIO (S3-совместимое хранилище) -----------------------------------------
MINIO_ROOT_USER=lawer-minio
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_password_here
MINIO_ACCESS_KEY=lawer-minio
MINIO_SECRET_KEY=CHANGE_ME_strong_password_here
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=lawer-documents

# --- Backend ------------------------------------------------------------------
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000

# --- Frontend -----------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- LLM (Ollama) ------------------------------------------------------------
LLM_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:1.5b
LLM_MAX_CONTEXT=10
LLM_TEMPERATURE=0.3
LLM_NUM_CTX=2048
LLM_NUM_PREDICT=1024
LLM_MAX_TOOL_ITERATIONS=3

# --- Admin seed (опционально) ------------------------------------------------
# Пароль для начального admin-пользователя (istadmin).
# Если не задан, сгенерируется автоматически и выведется в логи контейнера.
# ADMIN_PASSWORD=
