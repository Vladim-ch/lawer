# =============================================================
# Lawer Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!
# =============================================================

# Database
POSTGRES_DB=lawer
POSTGRES_USER=lawer
POSTGRES_PASSWORD=<generate-strong-password>
DATABASE_URL=postgresql://lawer:<POSTGRES_PASSWORD>@postgres:5432/lawer?schema=public

# Redis
REDIS_PASSWORD=<generate-strong-password>
REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379

# MinIO
MINIO_ROOT_USER=lawer_minio
MINIO_ROOT_PASSWORD=<generate-strong-password>
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=lawer_minio
MINIO_SECRET_KEY=<same-as-MINIO_ROOT_PASSWORD>
MINIO_BUCKET=lawer-documents

# JWT — use: openssl rand -base64 48
JWT_SECRET=<generate-strong-secret>
JWT_EXPIRES_IN=7d

# LLM
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# App
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
