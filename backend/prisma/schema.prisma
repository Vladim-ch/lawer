generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  lawyer
  viewer
}

enum MessageRole {
  user
  assistant
  system
}

enum TaskStatus {
  pending
  in_progress
  done
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  name         String   @db.VarChar(255)
  role         UserRole @default(lawyer)
  passwordHash       String   @map("password_hash") @db.VarChar(255)
  mustChangePassword Boolean  @default(true) @map("must_change_password")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  conversations Conversation[]
  documents     Document[]
  templates     Template[]
  tasks         Task[]
  knowledgeBase KnowledgeBase[]

  @@map("users")
}

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid()) @db.Uuid
  conversationId String      @map("conversation_id") @db.Uuid
  role           MessageRole
  content        String      @db.Text
  attachments    Json?       @db.JsonB
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model Document {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  filename    String   @db.VarChar(500)
  filePath    String   @map("file_path") @db.VarChar(1000)
  fileType    String   @map("file_type") @db.VarChar(50)
  contentText String?  @map("content_text") @db.Text
  fileSize    Int?     @map("file_size")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("documents")
}

model Template {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(255)
  category     String   @db.VarChar(100)
  templateBody String   @map("template_body") @db.Text
  parameters   Json     @db.JsonB
  createdBy    String   @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  creator User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@map("templates")
}

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  title       String     @db.VarChar(500)
  description String?    @db.Text
  deadline    DateTime?
  status      TaskStatus @default(pending)
  reminderAt  DateTime?  @map("reminder_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("tasks")
}

model LegalDocument {
  id          String   @id @default(uuid()) @db.Uuid
  filename    String   @db.VarChar(500)
  filePath    String   @unique @map("file_path") @db.VarChar(1000)
  title       String?  @db.VarChar(500)
  contentText String   @map("content_text") @db.Text
  pageCount   Int?     @map("page_count")
  fileSize    Int?     @map("file_size")
  indexedAt   DateTime @default(now()) @map("indexed_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([filename])
  @@map("legal_documents")
}

model KnowledgeBase {
  id        String   @id @default(uuid()) @db.Uuid
  title     String   @db.VarChar(500)
  content   String   @db.Text
  category  String   @db.VarChar(100)
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creator User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@map("knowledge_base")
}
